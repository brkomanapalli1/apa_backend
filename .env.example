# ═══════════════════════════════════════════════════════════════════════════
#  AI Paperwork Assistant (APA) — Environment Configuration
#  Copy to .env and fill in. Never commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────
APP_NAME="AI Paperwork Assistant"
APP_VERSION="1.0.0"
ENVIRONMENT=development      # development | staging | production

# ── Security (REQUIRED — generate strong values) ─────────────────────────
# openssl rand -hex 64
SECRET_KEY=change-me-generate-with-openssl-rand-hex-64
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:Myshopping@123@localhost:5432/paperwork_db

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Frontend ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Storage (MinIO) ───────────────────────────────────────────────────────
MINIO_INTERNAL_ENDPOINT=http://127.0.0.1:9000
MINIO_PUBLIC_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents

# ── AI / LLM ──────────────────────────────────────────────────────────────
# Options: anthropic | openai | mock
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# ── OCR ───────────────────────────────────────────────────────────────────
OCR_ENABLED=true
OCR_ENGINE=tesseract        # tesseract | paddleocr | textract
OCR_MAX_PAGES=20

# ── AWS (for Textract OCR upgrade) ───────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_TEXTRACT_REGION=us-east-1

# ── Email ─────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@aipaperworkassistant.com
SMTP_FROM_NAME="AI Paperwork Assistant"

# ── Push Notifications ────────────────────────────────────────────────────
EXPO_ACCESS_TOKEN=

# ── SMS (Twilio — for deadline reminders) ────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# ── Billing (Stripe) ──────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID_MONTHLY=
# STRIPE_PRICE_ID_FAMILY=

# ── Malware Scanning ──────────────────────────────────────────────────────
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
MALWARE_SCANNING_ENABLED=true

# ── Phase 2: Voice ────────────────────────────────────────────────────────
VOICE_ENABLED=false
# WHISPER_API_KEY=           ← OpenAI Whisper for speech-to-text
# TTS_PROVIDER=openai        ← openai | azure | disabled

# ── Phase 2: Translation ──────────────────────────────────────────────────
TRANSLATION_ENABLED=false
# TRANSLATION_PROVIDER=google   ← google | deepl | openai | disabled
# GOOGLE_TRANSLATE_API_KEY=

# ── Phase 2: Scam Detection ───────────────────────────────────────────────
SCAM_DETECTION_ENABLED=true
SCAM_CONFIDENCE_THRESHOLD=0.75

# ── Phase 2: Medication Tracking ─────────────────────────────────────────
MEDICATION_TRACKING_ENABLED=true

# ── [HIPAA] Compliance ────────────────────────────────────────────────────
AUDIT_LOG_RETENTION_DAYS=2555    # 7 years (HIPAA min: 6)
PHI_ENCRYPTION_AT_REST=true
HIPAA_MODE=true

# ── [HIPAA] Data Retention ────────────────────────────────────────────────
DATA_RETENTION_MEDICAL_DAYS=2555
DATA_RETENTION_UTILITY_DAYS=1095
DATA_RETENTION_FINANCIAL_DAYS=2555

# ── Data Sanitization ─────────────────────────────────────────────────────
SANITIZE_INPUT=true
MAX_INPUT_LENGTH=100000

# ── Observability ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json              # json | text
ENABLE_METRICS=true
# SENTRY_DSN=

# ── Feature Flags — Phase 1 (MVP) ─────────────────────────────────────────
FEATURE_DOCUMENT_UPLOAD=true
FEATURE_OCR=true
FEATURE_AI_SUMMARY=true
FEATURE_DEADLINE_DETECTION=true
FEATURE_DASHBOARD=true

# ── Feature Flags — Phase 2 (Smart Assistant) ─────────────────────────────
FEATURE_BILL_TRACKING=true
FEATURE_SCAM_DETECTION=true
FEATURE_MEDICATION_TRACKING=true
FEATURE_VOICE=false
FEATURE_SMART_REMINDERS=true

# ── Feature Flags — Phase 3 (Caregiver) ───────────────────────────────────
FEATURE_CAREGIVER_PORTAL=true
FEATURE_EMERGENCY_VAULT=true
FEATURE_RENEWAL_TRACKING=true

# ── Feature Flags — Phase 4 (Intelligent) ─────────────────────────────────
FEATURE_FORM_FILLING=false
FEATURE_FINANCIAL_ANALYSIS=false
FEATURE_BENEFITS_NAVIGATOR=false

# ── Feature Flags — Phase 5 (Premium) ────────────────────────────────────
FEATURE_AUTO_CLASSIFICATION=true
FEATURE_TIMELINE=false
FEATURE_TRANSLATION=false

# ── Admin ─────────────────────────────────────────────────────────────────
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
