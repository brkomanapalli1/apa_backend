# ── AI Paperwork Assistant — Backend .env ─────────────────────────────────
# Copy to .env and fill in. Never commit .env.

ENVIRONMENT=development
SECRET_KEY=change-me-generate-with-openssl-rand-hex-64

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/paperwork
REDIS_URL=redis://localhost:6379/0
FRONTEND_URL=http://localhost:3000

MINIO_INTERNAL_ENDPOINT=http://127.0.0.1:9000
MINIO_PUBLIC_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents

# AI — set LLM_PROVIDER=anthropic and add your key for full AI features
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=

SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com

EXPO_ACCESS_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

CLAMAV_HOST=clamav
CLAMAV_PORT=3310
MALWARE_SCANNING_ENABLED=true

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

DEFAULT_ADMIN_EMAIL=admin@example.com
LOG_LEVEL=INFO
AUDIT_LOG_RETENTION_DAYS=2555
